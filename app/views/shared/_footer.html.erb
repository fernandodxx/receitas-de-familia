<footer class="bg-marrom-argila text-white mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Sobre -->
      <div>
        <h3 class="text-2xl font-bold mb-4" style="font-family: 'Playfair Display', serif;">
          Receitas de Família
        </h3>
        <p class="text-gray-200 leading-relaxed">
          Preservando a tradição culinária brasileira.
          Receitas passadas de geração em geração,
          com amor e história.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="font-semibold text-lg mb-4">Categorias</h4>
        <ul class="space-y-2">
          <li><%= link_to 'Entradas', category_path('entrada'), class: 'text-gray-200 hover:text-amarelo-gema transition' %></li>
          <li><%= link_to 'Pratos Principais', category_path('prato_principal'), class: 'text-gray-200 hover:text-amarelo-gema transition' %></li>
          <li><%= link_to 'Sobremesas', category_path('sobremesa'), class: 'text-gray-200 hover:text-amarelo-gema transition' %></li>
          <li><%= link_to 'Bebidas', category_path('bebida'), class: 'text-gray-200 hover:text-amarelo-gema transition' %></li>
        </ul>
      </div>

      <!-- Regiões -->
      <div>
        <h4 class="font-semibold text-lg mb-4">Regiões</h4>
        <ul class="space-y-2">
          <li><%= link_to 'Norte', region_path('norte'), class: 'text-gray-200 hover:text-amarelo-gema transition' %></li>
          <li><%= link_to 'Nordeste', region_path('nordeste'), class: 'text-gray-200 hover:text-amarelo-gema transition' %></li>
          <li><%= link_to 'Sudeste', region_path('sudeste'), class: 'text-gray-200 hover:text-amarelo-gema transition' %></li>
          <li><%= link_to 'Sul', region_path('sul'), class: 'text-gray-200 hover:text-amarelo-gema transition' %></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/20 mt-8 pt-8 text-center text-gray-300">
      <p>&copy; <%= Time.current.year %> Receitas de Família. Feito com <span class="text-vermelho-urucum">❤</span>.</p>
    </div>
  </div>
</footer>
