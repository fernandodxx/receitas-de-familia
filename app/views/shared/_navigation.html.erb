<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <%= link_to root_path, class: 'flex items-center gap-2' do %>
        <span class="text-2xl font-bold text-terracota" style="font-family: 'Playfair Display', serif;">
          Receitas de Família
        </span>
      <% end %>

      <!-- Busca Desktop -->
      <div class="hidden md:block flex-1 max-w-lg mx-8">
        <%= form_with url: search_path, method: :get, class: 'relative' do |f| %>
          <%= f.text_field :q,
              placeholder: 'Buscar receitas...',
              class: 'w-full pl-4 pr-10 py-2 bg-gray-100 border-0 rounded-full focus:outline-none focus:ring-2 focus:ring-terracota focus:bg-white transition',
              value: params[:q] %>
          <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 hover:text-terracota">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </button>
        <% end %>
      </div>

      <!-- Navegação -->
      <nav class="hidden md:flex items-center gap-6">
        <%= link_to 'Nova Receita', new_recipe_path,
            class: 'btn-primary' %>

        <!-- Favoritos -->
        <button id="favorites-btn" class="flex items-center gap-1 text-marrom-argila hover:text-terracota transition">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
          </svg>
          <span id="favorites-count" class="text-sm font-medium">0</span>
        </button>
      </nav>

      <!-- Menu Mobile -->
      <button id="mobile-menu-btn" class="md:hidden p-2 text-marrom-argila">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Menu Mobile Dropdown -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <%= form_with url: search_path, method: :get, class: 'mb-4' do |f| %>
        <%= f.text_field :q,
            placeholder: 'Buscar receitas...',
            class: 'w-full px-4 py-2 bg-gray-100 border-0 rounded-full focus:outline-none focus:ring-2 focus:ring-terracota' %>
      <% end %>

      <div class="flex flex-col gap-2">
        <%= link_to 'Nova Receita', new_recipe_path,
            class: 'btn-primary text-center' %>
      </div>
    </div>
  </div>
</header>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', function() {
    const menu = document.getElementById('mobile-menu');
    menu.classList.toggle('hidden');
  });
</script>
