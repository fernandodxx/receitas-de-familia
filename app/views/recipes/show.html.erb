<% content_for :title, "Receita de #{@recipe.title} da vovó | Receitas de Família" %>
<% content_for :description, @recipe.description.truncate(160) %>

<!-- Schema.org JSON-LD -->
<% content_for :head do %>
  <script type="application/ld+json">
  <%= raw({
    "@context": "https://schema.org",
    "@type": "Recipe",
    "name": @recipe.title,
    "description": @recipe.description,
    "image": @recipe.image_url,
    "prepTime": @recipe.prep_time ? "PT#{@recipe.prep_time}M" : nil,
    "recipeYield": @recipe.servings ? "#{@recipe.servings} porções" : nil,
    "recipeIngredient": @recipe.ingredients.split(/\r?\n/).map(&:strip).reject(&:blank?),
    "recipeInstructions": @recipe.instructions.split(/\r?\n/).map(&:strip).reject(&:blank?).map { |step|
      { "@type": "HowToStep", "text": step }
    },
    "author": {
      "@type": "Organization",
      "name": "Receitas de Família"
    }
  }.compact.to_json) %>
  </script>
<% end %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
    <%= link_to 'Início', root_path, class: 'hover:text-terracota' %>
    <span>/</span>
    <%= link_to @recipe.category.humanize, category_path(@recipe.category), class: 'hover:text-terracota' %>
    <span>/</span>
    <span class="text-gray-900"><%= @recipe.title %></span>
  </nav>

  <!-- Header da Receita -->
  <header class="mb-8">
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="px-3 py-1 bg-terracota/10 text-terracota text-sm font-medium rounded-full">
        <%= @recipe.category.humanize %>
      </span>
      <% if @recipe.region != 'geral' %>
        <span class="px-3 py-1 bg-ocre/20 text-marrom-argila text-sm font-medium rounded-full">
          <%= @recipe.region.humanize %>
        </span>
      <% end %>
      <% if @recipe.occasion != 'dia_a_dia' %>
        <span class="px-3 py-1 bg-verde-folha/10 text-verde-folha text-sm font-medium rounded-full">
          <%= @recipe.occasion.humanize %>
        </span>
      <% end %>
    </div>

    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4" style="font-family: 'Playfair Display', serif;">
      <%= @recipe.title %>
    </h1>

    <p class="text-xl text-gray-600 leading-relaxed">
      <%= @recipe.description %>
    </p>
  </header>

  <!-- Imagem Principal -->
  <% if @recipe.image_url.present? %>
    <div class="mb-8">
      <img src="<%= @recipe.image_url %>" alt="<%= @recipe.title %>"
           class="w-full h-96 object-cover rounded-2xl shadow-lg">
    </div>
  <% end %>

  <!-- Informações Rápidas -->
  <div class="flex flex-wrap gap-6 mb-8 p-6 bg-white rounded-xl shadow-sm">
    <% if @recipe.prep_time %>
      <div class="flex items-center gap-3">
        <div class="p-3 bg-terracota/10 rounded-full">
          <svg class="w-6 h-6 text-terracota" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm text-gray-500">Tempo de Preparo</p>
          <p class="font-semibold text-gray-900"><%= @recipe.prep_time %> min</p>
        </div>
      </div>
    <% end %>

    <% if @recipe.servings %>
      <div class="flex items-center gap-3">
        <div class="p-3 bg-verde-folha/10 rounded-full">
          <svg class="w-6 h-6 text-verde-folha" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm text-gray-500">Rendimento</p>
          <p class="font-semibold text-gray-900"><%= @recipe.servings %> porções</p>
        </div>
      </div>
    <% end %>

    <!-- Botão Favoritar -->
    <div class="ml-auto">
      <button id="recipe-favorite-btn" class="favorite-btn flex items-center gap-2 px-6 py-3 border-2 border-terracota text-terracota rounded-full font-medium hover:bg-terracota hover:text-white transition"
              data-recipe-id="<%= @recipe.id %>">
        <svg class="w-5 h-5 heart-icon" fill="currentColor" viewBox="0 0 24 24">
          <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
        <span class="favorite-text">Favoritar</span>
      </button>
    </div>
  </div>

  <!-- Conteúdo em Grid -->
  <div class="grid md:grid-cols-3 gap-8">
    <!-- Sidebar: Ingredientes -->
    <aside class="md:col-span-1">
      <div class="bg-white p-6 rounded-xl shadow-sm sticky top-24">
        <h2 class="text-2xl font-bold text-gray-900 mb-6" style="font-family: 'Playfair Display', serif;">
          Ingredientes
        </h2>

        <ul class="space-y-3">
          <% @recipe.ingredients.split(/\r?\n/).map(&:strip).reject(&:blank?).each do |ingredient| %>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 bg-terracota rounded-full mt-2 flex-shrink-0"></span>
              <span class="text-gray-700"><%= ingredient %></span>
            </li>
          <% end %>
        </ul>

        <!-- MONETIZAÇÃO: Links de afiliados - após ingredientes -->
        <div class="mt-6 p-4 bg-gray-50 rounded-lg border border-gray-200">
          <p class="text-xs text-gray-500 text-center">
            <!-- Espaço reservado para links de afiliados (utensílios, ingredientes, etc.) -->
          </p>
        </div>
      </div>
    </aside>

    <!-- Main: Modo de Preparo -->
    <article class="md:col-span-2">
      <div class="bg-white p-8 rounded-xl shadow-sm">
        <h2 class="text-2xl font-bold text-gray-900 mb-6" style="font-family: 'Playfair Display', serif;">
          Modo de Preparo
        </h2>

        <ol class="space-y-6">
          <% @recipe.instructions.split(/\r?\n/).map(&:strip).reject(&:blank?).each_with_index do |step, index| %>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-terracota text-white rounded-full flex items-center justify-center font-semibold text-sm">
                <%= index + 1 %>
              </span>
              <p class="text-gray-700 leading-relaxed pt-1"><%= step %></p>
            </li>
          <% end %>
        </ol>

        <!-- MONETIZAÇÃO: Links de afiliados - após modo de preparo -->
        <div class="mt-8 p-6 bg-gray-50 rounded-lg border border-gray-200">
          <p class="text-xs text-gray-500 text-center">
            <!-- Espaço reservado para links de afiliados (livros de receitas, cursos, etc.) -->
          </p>
        </div>
      </div>

      <!-- Comentários -->
      <div id="comentarios" class="mt-8 bg-white p-8 rounded-xl shadow-sm">
        <h2 class="text-2xl font-bold text-gray-900 mb-6" style="font-family: 'Playfair Display', serif;">
          Comentários (<%= @comments.count %>)
        </h2>

        <!-- Formulário de Comentário -->
        <%= form_with model: [@recipe, @comment], class: 'mb-8' do |f| %>
          <div class="mb-4">
            <%= f.label :author_name, 'Seu Nome', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.text_field :author_name, placeholder: 'Anônimo',
                class: 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-terracota' %>
          </div>

          <div class="mb-4">
            <%= f.label :content, 'Comentário', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.text_area :content, rows: 4, placeholder: 'Compartilhe sua experiência com esta receita...',
                class: 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-terracota' %>
          </div>

          <%= f.submit 'Enviar Comentário',
              class: 'btn-primary cursor-pointer' %>
        <% end %>

        <!-- Lista de Comentários -->
        <% if @comments.any? %>
          <div class="space-y-6">
            <% @comments.each do |comment| %>
              <div class="pb-6 border-b border-gray-100 last:border-0">
                <div class="flex items-center gap-3 mb-2">
                  <div class="w-10 h-10 bg-ocre/30 rounded-full flex items-center justify-center">
                    <span class="text-marrom-argila font-semibold">
                      <%= comment.author_name[0].upcase %>
                    </span>
                  </div>
                  <div>
                    <p class="font-medium text-gray-900"><%= comment.author_name %></p>
                    <p class="text-sm text-gray-500">
                      <%= l(comment.created_at, format: :long) %>
                    </p>
                  </div>
                </div>
                <p class="text-gray-700"><%= comment.content %></p>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500 text-center py-8">Seja o primeiro a comentar! 🍳</p>
        <% end %>
      </div>
    </article>
  </div>

  <!-- Ações de Admin -->
  <div class="mt-8 flex gap-4">
    <%= link_to 'Editar Receita', edit_recipe_path(@recipe),
        class: 'bg-gray-100 text-gray-700 px-6 py-3 rounded-lg font-medium hover:bg-gray-200 transition' %>

    <%= button_to 'Excluir Receita', @recipe, method: :delete,
        class: 'bg-red-100 text-red-700 px-6 py-3 rounded-lg font-medium hover:bg-red-200 transition',
        data: { confirm: 'Tem certeza que deseja excluir esta receita?' } %>
  </div>
</div>
