<div class="recipe-card bg-white card-organic overflow-hidden shadow-md">
  <% if recipe.image_url.present? %>
    <div class="relative h-48 overflow-hidden">
      <img src="<%= recipe.image_url %>" alt="<%= recipe.title %>"
           class="w-full h-full object-cover transition-transform duration-500 hover:scale-105">

      <!-- Badge de favorito -->
      <button class="favorite-btn absolute top-3 right-3 p-2 bg-white/90 rounded-full shadow-sm hover:bg-white transition"
              data-recipe-id="<%= recipe.id %>"
              aria-label="Adicionar aos favoritos">
        <svg class="w-5 h-5 text-gray-400 heart-icon" fill="currentColor" viewBox="0 0 24 24">
          <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
      </button>
    </div>
  <% end %>

  <div class="p-5">
    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs font-semibold text-terracota uppercase tracking-wide">
        <%= recipe.category.humanize %>
      </span>
      <% if recipe.region != 'geral' %>
        <span class="text-xs text-gray-400">•</span>
        <span class="text-xs text-gray-500">
          <%= recipe.region.humanize %>
        </span>
      <% end %>
    </div>

    <h3 class="text-xl font-bold text-gray-900 mb-2" style="font-family: 'Playfair Display', serif;">
      <%= link_to recipe.title, recipe, class: 'hover:text-terracota transition' %>
    </h3>

    <p class="text-gray-600 text-sm mb-4 line-clamp-2">
      <%= recipe.description %>
    </p>

    <div class="flex items-center justify-between text-sm text-gray-500">
      <div class="flex items-center gap-3">
        <% if recipe.prep_time %>
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <%= recipe.prep_time %> min
          </span>
        <% end %>

        <% if recipe.servings %>
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <%= recipe.servings %>
          </span>
        <% end %>
      </div>

      <span class="text-terracota font-medium">
        Ver mais →
      </span>
    </div>
  </div>
</div>
