<% content_for :title, "Buscar: #{@query} | Receitas de Família" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900" style="font-family: 'Playfair Display', serif;">
      Resultados da Busca
    </h1>
    <p class="text-gray-600 mt-2">
      <% if @query.present? %>
        Buscando por: <span class="font-medium text-terracota">"<%= @query %>"</span>
      <% else %>
        Digite um termo para buscar receitas
      <% end %>
    </p>
  </div>

  <% if @recipes.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
      <% @recipes.each do |recipe| %>
        <%= render 'recipes/recipe_card', recipe: recipe %>
      <% end %>
    </div>
  <% elsif @query.present? %>
    <div class="text-center py-16">
      <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <p class="text-gray-500 text-lg mb-4">Nenhuma receita encontrada para "<%= @query %>"</p>
      <%= link_to 'Ver Todas as Receitas', root_path,
          class: 'btn-primary inline-block' %>
    </div>
  <% end %>
</div>
